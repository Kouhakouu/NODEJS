PORT=8000
NODE_ENV=development

# PostgreSQL (Neon) - lấy connection string ở Neon Dashboard > Connection Details
# dạng: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Cloudinary - lấy từ Dashboard sau khi đăng ký tài khoản (free)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
